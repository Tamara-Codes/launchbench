# ---------------------------------------------------------------------------
# Founder Workbench — local sales assistant. Copy this file to `.env.local` and fill in.
# All keys are server-only and must NEVER be exposed to the browser.
# ---------------------------------------------------------------------------

# Local SQLite database file (relative to project root). Legacy local mode
# only; production SaaS records live in Supabase.
DATABASE_URL=./data/sales-agent.db

# Supabase SaaS foundation. These are required when enabling multi-tenant mode.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=  # server-only; never expose in the browser
WORKFLOWS_ENABLED=false     # set true only after tenant agent handlers are migrated
# Optional incident webhook (Slack, Better Uptime, etc.). Never put this in a
# NEXT_PUBLIC variable. Alerts contain only redacted operational metadata.
OPERATIONAL_ALERTS_ENABLED=false
ALERT_WEBHOOK_URL=
# Vercel Cron authenticates the recovery endpoint with this server-only value.
CRON_SECRET=

# AI-provider credentials are deployment configuration. They are never entered
# by app users and must remain server-only.
GEMINI_API_KEY=
# Google Gemini model used by the Lead Finder.
GEMINI_MODEL=gemini-3.5-flash


# Firecrawl (https://www.firecrawl.dev/app/api-keys)
FIRECRAWL_API_KEY=

# Google business discovery. Enable Places API (New) in Google Cloud.
GOOGLE_PLACES_API_KEY=

# Google web search, through a Programmable Search Engine.
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# Composio (https://app.composio.dev) — Gmail integration.
COMPOSIO_API_KEY=
# The Gmail auth-config id created in the Composio dashboard (Auth Configs → Gmail).
COMPOSIO_AUTH_CONFIG_ID=

# Public app URL (used to build the Gmail OAuth callback). Localhost only.
NEXT_PUBLIC_APP_URL=http://localhost:3000
